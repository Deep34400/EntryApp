{
  "expo": {
    "name": "Gate Entry",
    "slug": "gate-entry",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "gateentry",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": "sdkVersion",
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gateentry.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#B31D38",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.gateentry.app"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/app-icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#B31D38",
          "dark": {
            "backgroundColor": "#B31D38"
          }
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "09511a6a-5a9e-46b1-9c05-4b25b5d190e5"
      }
    }
  }
}
