# development = internal (100 apps testing). production = deploy.
APP_TYPE=development

# ─── Backend API URL — the app calls this URL for all API requests ──────
# local environment
# EXPO_PUBLIC_API_URL=https://qrm792qn-3000.inc1.devtunnels.ms/


# production: set APP_TYPE=production
# EXPO_PUBLIC_API_URL=https://api.carrum.co.in/

# development: set APP_TYPE=development
EXPO_PUBLIC_API_URL=https://api-dev-v2.carrum.co.in/

# Option B: For Replit — set in package.json "expo:dev" script instead:
# EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000

# After changing, restart the Expo app so it picks up the new value.
